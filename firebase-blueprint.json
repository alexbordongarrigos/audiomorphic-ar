{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "subscriptionTier": {
          "type": "string",
          "enum": ["free", "trial", "annual", "lifetime"],
          "description": "The user's current subscription tier"
        },
        "trialEndTime": {
          "type": "number",
          "description": "The timestamp when the trial ends, if applicable"
        },
        "createdAt": {
          "type": "number",
          "description": "The timestamp when the user was created"
        },
        "updatedAt": {
          "type": "number",
          "description": "The timestamp when the user was last updated"
        }
      },
      "required": ["uid", "email", "subscriptionTier", "createdAt", "updatedAt"]
    },
    "Preset": {
      "title": "Preset",
      "description": "A saved visualizer preset",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the preset"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this preset"
        },
        "name": {
          "type": "string",
          "description": "The name of the preset"
        },
        "params": {
          "type": "string",
          "description": "JSON stringified visualizer parameters"
        },
        "createdAt": {
          "type": "number",
          "description": "The timestamp when the preset was created"
        }
      },
      "required": ["uid", "userId", "name", "params", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and subscription data"
    },
    "presets/{presetId}": {
      "schema": {
        "$ref": "#/entities/Preset"
      },
      "description": "Stores saved visualizer presets"
    }
  }
}
